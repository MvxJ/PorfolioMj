---
/* BaseSection.astro — inherited section shell: bg / width / padding / id / label.
   Every content section composes this; spacing & width behaviour live here once. */
interface Props {
  bg?: 'none' | 'subtle' | 'card' | 'accent' | 'contrast';
  width?: 'narrow' | 'normal' | 'wide' | 'full';
  pad?: 'sm' | 'md' | 'lg' | 'xl';
  id?: string;
  label?: string;
  class?: string;
  labelledby?: string;
  style?: string;
  /** grow to fill the leftover viewport height + vertically center content */
  fill?: boolean;
}
const {
  bg = 'none',
  width = 'normal',
  pad = 'lg',
  id,
  label,
  labelledby,
  class: className = '',
  style,
  fill = false,
} = Astro.props;
---
<section
  id={id}
  data-screen-label={label}
  aria-labelledby={labelledby}
  class={`section bg-${bg} w-${width} pad-${pad} ${fill ? 'section--fill' : ''} ${className}`.trim()}
  style={style}
>
  <div class="container">
    <slot />
  </div>
</section>
