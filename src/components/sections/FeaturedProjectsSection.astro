---
/* FeaturedProjectsSection.astro — first 2 projects + "view all" link. */
import type { Locale } from '../../i18n';
import { useT } from '../../i18n';
import { localizedPath } from '../../lib/routing';
import { getProjects, getAppearance } from '../../lib/content';
import BaseSection from '../BaseSection.astro';
import ProjectCard from '../molecules/ProjectCard.astro';
import Button from '../primitives/Button.astro';
import TiltCard from '../islands/TiltCard.tsx';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useT(locale);
const projects = (await getProjects()).slice(0, 2);
const appearance = await getAppearance();
const useTilt = appearance.animations && appearance.hoverEffect === 'tilt';
---
<BaseSection id="featured" pad="lg" labelledby="featured-title">
  <div class="section-head">
    <p class="eyebrow aos">{t('sections.featuredEyebrow')}</p>
    <h2 class="section-title aos" id="featured-title">{t('sections.featuredTitle')}</h2>
  </div>
  <div class="card-grid">
    {projects.map((project) => (
      <div class="aos">
        {useTilt ? (
          <TiltCard client:visible>
            <ProjectCard project={project} locale={locale} />
          </TiltCard>
        ) : (
          <ProjectCard project={project} locale={locale} />
        )}
      </div>
    ))}
  </div>
  <div style="margin-top:2.5rem;" class="aos">
    <Button href={localizedPath(locale, 'projects')} variant="secondary">{t('actions.viewAll')}</Button>
  </div>
</BaseSection>
