---
/* Flag.astro — renders flag-{pl,en,uk}.svg keeping its literal colors and 3:2 ratio. */
import type { Locale } from '../../i18n';
interface Props {
  locale: Locale;
  class?: string;
}
const { locale, class: className = '' } = Astro.props;

const files = import.meta.glob<string>('../../assets/icons/flag-*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const svg = files[`../../assets/icons/flag-${locale}.svg`];
if (!svg) throw new Error(`Flag for locale "${locale}" not found`);
---
<span class={`flag ${className}`} aria-hidden="true" set:html={svg} />
